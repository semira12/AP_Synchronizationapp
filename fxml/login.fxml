<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.syncstream.gui.LoginController"
      alignment="CENTER" spacing="15" style="-fx-background-color: #1a1a2e;">

    <padding><Insets top="40" right="60" bottom="40" left="60"/></padding>

    <!-- Title -->
    <Label fx:id="titleLabel" text="🎬 SyncStream"
           style="-fx-font-size: 28; -fx-text-fill: #e94560; -fx-font-weight: bold;"/>
    <Label text="Watch together, anywhere."
           style="-fx-font-size: 14; -fx-text-fill: #aaaaaa;"/>

    <Separator style="-fx-background-color: #333355;" prefWidth="300"/>

    <!-- Server host -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Server:" style="-fx-text-fill: #cccccc; -fx-min-width: 80;"/>
        <TextField fx:id="hostField" promptText="localhost" prefWidth="200"
                   style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-border-color: #333355;"/>
    </HBox>

    <!-- Username -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Username:" style="-fx-text-fill: #cccccc; -fx-min-width: 80;"/>
        <TextField fx:id="usernameField" promptText="your username" prefWidth="200"
                   style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-border-color: #333355;"/>
    </HBox>

    <!-- Email (register only) -->
    <HBox fx:id="emailRow" alignment="CENTER_LEFT" spacing="10">
        <Label fx:id="emailLabel" text="Email:" style="-fx-text-fill: #cccccc; -fx-min-width: 80;"/>
        <TextField fx:id="emailField" promptText="your@email.com" prefWidth="200"
                   style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-border-color: #333355;"/>
    </HBox>

    <!-- Password -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Password:" style="-fx-text-fill: #cccccc; -fx-min-width: 80;"/>
        <PasswordField fx:id="passwordField" promptText="password" prefWidth="200"
                       style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-border-color: #333355;"/>
    </HBox>

    <Separator style="-fx-background-color: #333355;" prefWidth="300"/>

    <!-- Status -->
    <Label fx:id="statusLabel" text=""
           style="-fx-text-fill: #e94560; -fx-font-size: 12;"/>

    <!-- Buttons -->
    <HBox alignment="CENTER" spacing="20">
        <Button fx:id="loginButton" text="Login" onAction="#onLogin" prefWidth="120"
                style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button fx:id="registerButton" text="Register" onAction="#onRegister" prefWidth="120"
                style="-fx-background-color: #16213e; -fx-text-fill: #e94560; -fx-border-color: #e94560; -fx-cursor: hand;"/>
    </HBox>
</VBox>
